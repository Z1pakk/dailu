{
  "openapi": "3.1.1",
  "info": {
    "title": "Dailo.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/habits": {
      "post": {
        "tags": [
          "Habit"
        ],
        "description": "Creates a new habit for the current authenticated user.",
        "operationId": "CreateHabit",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHabitCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateHabitResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Habit"
        ],
        "description": "Get habits for the current authenticated user.",
        "operationId": "GetHabits",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetHabitsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/habits/{id}": {
      "put": {
        "tags": [
          "Habit"
        ],
        "description": "Updates an existing habit for the current authenticated user.",
        "operationId": "UpdateHabit",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateHabitCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/habit-entries": {
      "post": {
        "tags": [
          "HabitEntryModel"
        ],
        "description": "Creates a new habit entry for the current authenticated user.",
        "operationId": "CreateHabitEntry",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHabitEntryCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateHabitEntryResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "HabitEntryModel"
        ],
        "description": "Get habit entries for the current authenticated user.",
        "operationId": "GetHabitEntries",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetHabitEntriesQueryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/habit-user/profile": {
      "get": {
        "tags": [
          "HabitUser"
        ],
        "description": "Get user profile for the current authenticated user.",
        "operationId": "GetUserProfile",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetUserProfileResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "HabitUser"
        ],
        "description": "Updates user profile for the current authenticated user.",
        "operationId": "UpdateUserProfile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserProfileRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/habit-user/integrations": {
      "get": {
        "tags": [
          "HabitUser"
        ],
        "description": "Get integration summaries for the current authenticated user.",
        "operationId": "GetIntegrationConfigs",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetIntegrationConfigsResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "HabitUser"
        ],
        "description": "Saves integration config for the current authenticated user.",
        "operationId": "SaveIntegrationConfig",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IntegrationConfig"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/habit-user/integrations/{provider}": {
      "delete": {
        "tags": [
          "HabitUser"
        ],
        "description": "Revokes an integration config for the current authenticated user.",
        "operationId": "DeleteIntegrationConfig",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/api/tags": {
      "post": {
        "tags": [
          "Tag"
        ],
        "description": "Creates a new tag for the current authenticated user.",
        "operationId": "CreateTag",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTagCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTagResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Tag"
        ],
        "description": "Get tags for the current authenticated user.",
        "operationId": "GetTags",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetTagsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Identity"
        ],
        "description": "Login a user with email and password. Returns access and refresh tokens if successful.",
        "operationId": "LoginUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginUserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Identity"
        ],
        "description": "Registers a new user with the provided email, password, first name, and last name. Returns access tokens upon successful registration.",
        "operationId": "RegisterUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserCommand"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": [
          "Identity"
        ],
        "description": "Refreshes the access token using a valid refresh token. Returns new access and refresh tokens if the provided refresh token is valid.",
        "operationId": "Refresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/RefreshCommand"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Identity"
        ],
        "description": "Invalidates the current refresh token and clears the session cookie.",
        "operationId": "Logout",
        "responses": {
          "204": {
            "description": "No Content"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/altcha-challenge": {
      "get": {
        "tags": [
          "Identity"
        ],
        "description": "Returns an Altcha proof-of-work challenge for CAPTCHA verification.",
        "operationId": "GetAltchaChallenge",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AltchaChallengeModel"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AccessTokenModel": {
        "required": [
          "accessToken",
          "refreshToken",
          "refreshTokenExpiration"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "refreshTokenExpiration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AltchaChallengeModel": {
        "required": [
          "parameters",
          "signature"
        ],
        "type": "object",
        "properties": {
          "parameters": {
            "$ref": "#/components/schemas/AltchaChallengeParameters"
          },
          "signature": {
            "type": "string"
          }
        }
      },
      "AltchaChallengeParameters": {
        "required": [
          "algorithm",
          "cost",
          "keyPrefix",
          "nonce",
          "salt"
        ],
        "type": "object",
        "properties": {
          "algorithm": {
            "type": "string"
          },
          "cost": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "keyPrefix": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "salt": {
            "type": "string"
          }
        }
      },
      "CreateHabitCommand": {
        "required": [
          "name",
          "description",
          "type",
          "frequency",
          "target",
          "endDate",
          "milestone",
          "tagIds"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "type": {
            "$ref": "#/components/schemas/HabitType"
          },
          "frequency": {
            "$ref": "#/components/schemas/FrequencyModel"
          },
          "target": {
            "$ref": "#/components/schemas/TargetModel"
          },
          "endDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "milestone": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MilestoneModel"
              }
            ]
          },
          "tagIds": {
            "type": "array"
          }
        }
      },
      "CreateHabitEntryCommand": {
        "required": [
          "habitId",
          "value",
          "notes",
          "completedAt"
        ],
        "type": "object",
        "properties": {
          "habitId": {
            "$ref": "#/components/schemas/Id"
          },
          "value": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "completedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateHabitEntryResponse": {
        "required": [
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IdOfHabitEntryModel"
          }
        }
      },
      "CreateHabitResponse": {
        "required": [
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IdOfHabitModel"
          }
        }
      },
      "CreateTagCommand": {
        "required": [
          "name",
          "description"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateTagResponse": {
        "required": [
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IdOfTagModel"
          }
        }
      },
      "FrequencyModel": {
        "required": [
          "type",
          "timesPerPeriod"
        ],
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/FrequencyType"
          },
          "timesPerPeriod": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "FrequencyType": {
        "type": "integer"
      },
      "GetHabitEntriesQueryResponse": {
        "required": [
          "habitEntries"
        ],
        "type": "object",
        "properties": {
          "habitEntries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HabitEntryModel"
            }
          }
        }
      },
      "GetHabitsResponse": {
        "required": [
          "habits"
        ],
        "type": "object",
        "properties": {
          "habits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HabitModel"
            }
          }
        }
      },
      "GetIntegrationConfigsResponse": {
        "required": [
          "summaries"
        ],
        "type": "object",
        "properties": {
          "summaries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IntegrationSummary"
            }
          }
        }
      },
      "GetTagsResponse": {
        "required": [
          "tags"
        ],
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagModel"
            }
          }
        }
      },
      "GetUserProfileResponse": {
        "required": [
          "profile"
        ],
        "type": "object",
        "properties": {
          "profile": {
            "$ref": "#/components/schemas/UserProfileModel"
          }
        }
      },
      "HabitEntryModel": {
        "required": [
          "id",
          "habitId",
          "habitName",
          "value",
          "source",
          "completedAtUtc"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IdOfHabitEntryModel"
          },
          "habitId": {
            "$ref": "#/components/schemas/Id"
          },
          "habitName": {
            "type": "string"
          },
          "value": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "source": {
            "$ref": "#/components/schemas/HabitEntrySource"
          },
          "externalId": {
            "type": [
              "null",
              "string"
            ]
          },
          "completedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "isArchived": {
            "type": "boolean"
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "lastModifiedAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "HabitEntrySource": {
        "type": "integer"
      },
      "HabitModel": {
        "required": [
          "id",
          "name",
          "type",
          "frequency",
          "target",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/IdOfHabitModel"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": [
              "null",
              "string"
            ]
          },
          "type": {
            "$ref": "#/components/schemas/HabitType"
          },
          "frequency": {
            "$ref": "#/components/schemas/FrequencyModel"
          },
          "target": {
            "$ref": "#/components/schemas/TargetModel"
          },
          "status": {
            "$ref": "#/components/schemas/HabitStatus"
          },
          "isArchived": {
            "type": "boolean"
          },
          "endDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "milestone": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MilestoneModel"
              }
            ]
          },
          "createdAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "lastCompletedAtUtc": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TagModel"
            }
          }
        }
      },
      "HabitStatus": {
        "type": "integer"
      },
      "HabitType": {
        "type": "integer"
      },
      "Id": { },
      "IdOfHabitEntryModel": { },
      "IdOfHabitModel": { },
      "IdOfTagModel": { },
      "IntegrationConfig": {
        "required": [
          "type"
        ],
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/IntegrationConfigGithubIntegrationConfig"
          },
          {
            "$ref": "#/components/schemas/IntegrationConfigStravaIntegrationConfig"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "github": "#/components/schemas/IntegrationConfigGithubIntegrationConfig",
            "strava": "#/components/schemas/IntegrationConfigStravaIntegrationConfig"
          }
        }
      },
      "IntegrationConfigGithubIntegrationConfig": {
        "required": [
          "accessToken",
          "expiresInDays"
        ],
        "properties": {
          "type": {
            "enum": [
              "github"
            ],
            "type": "string"
          },
          "accessToken": {
            "type": "string"
          },
          "expiresInDays": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "IntegrationConfigStravaIntegrationConfig": {
        "required": [
          "clientId",
          "clientSecret"
        ],
        "properties": {
          "type": {
            "enum": [
              "strava"
            ],
            "type": "string"
          },
          "clientId": {
            "type": "string"
          },
          "clientSecret": {
            "type": "string"
          }
        }
      },
      "IntegrationSummary": {
        "required": [
          "type"
        ],
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/IntegrationSummaryGithubIntegrationSummary"
          },
          {
            "$ref": "#/components/schemas/IntegrationSummaryStravaIntegrationSummary"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "github": "#/components/schemas/IntegrationSummaryGithubIntegrationSummary",
            "strava": "#/components/schemas/IntegrationSummaryStravaIntegrationSummary"
          }
        }
      },
      "IntegrationSummaryGithubIntegrationSummary": {
        "required": [
          "expiresAt"
        ],
        "properties": {
          "type": {
            "enum": [
              "github"
            ],
            "type": "string"
          },
          "expiresAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "IntegrationSummaryStravaIntegrationSummary": {
        "properties": {
          "type": {
            "enum": [
              "strava"
            ],
            "type": "string"
          }
        }
      },
      "LoginUserCommand": {
        "required": [
          "email",
          "password",
          "captchaPayload"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "captchaPayload": {
            "type": "string"
          }
        }
      },
      "LoginUserResponse": {
        "required": [
          "accessTokens"
        ],
        "type": "object",
        "properties": {
          "accessTokens": {
            "$ref": "#/components/schemas/AccessTokenModel"
          }
        }
      },
      "MilestoneModel": {
        "required": [
          "target",
          "current"
        ],
        "type": "object",
        "properties": {
          "target": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "current": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
